#!/bin/zsh

set -euo pipefail

source "$(cd "$(dirname "$0")" && pwd)/lib/xcode-env.sh"

ensure_dirs
require_project

SMOKE="${1:-}"
if [[ "${SMOKE}" != "--smoke" ]]; then
  echo "test-ui-macos currently supports --smoke mode only" >&2
  exit 1
fi

"${ROOT_DIR}/scripts/capture-checkpoint" \
  --scenario "${APP_SMOKE_SCENARIO_NAME}" \
  --platform-target macos \
  --checkpoint shell-smoke-macos

python3 - "${CHECKPOINTS_DIR}/shell-smoke-macos" "${APP_SMOKE_SCENARIO_NAME}" <<'PY'
import json
import pathlib
import sys

root = pathlib.Path(sys.argv[1])
scenario_name = sys.argv[2]
state = json.loads(root.joinpath("state.json").read_text())

assert state["platform"] == "macos"
assert state["deviceClass"] == "mac"
assert state["selectedScenario"] == scenario_name
assert state["connectedAccountCount"] >= 2
assert state["selectedCalendarCount"] >= 2
assert "mirrorPreview" in state
assert root.joinpath("window.png").exists()
print("macOS smoke ok")
PY
