#!/bin/zsh

set -euo pipefail

source "$(cd "$(dirname "$0")" && pwd)/lib/xcode-env.sh"

ensure_dirs
sync_google_client_config
load_local_env

command -v xcodebuild >/dev/null || { echo "xcodebuild is missing" >&2; exit 1; }
command -v swift >/dev/null || { echo "swift is missing" >&2; exit 1; }
command -v python3 >/dev/null || { echo "python3 is missing" >&2; exit 1; }

IPHONE_ID=""
IPAD_ID=""
if IPHONE_ID="$(iphone_sim_id 2>/dev/null || true)"; then
  :
fi
if IPAD_ID="$(ipad_sim_id 2>/dev/null || true)"; then
  :
fi

echo "project: ${PROJECT_PATH}"
if [[ -d "${PROJECT_PATH}" ]]; then
  xcodebuild -list -project "${PROJECT_PATH}" >/dev/null
  echo "project-status: present"
else
  echo "project-status: missing"
fi
echo "scheme: ${SCHEME_NAME}"
echo "derived-data: ${DERIVED_DATA_DIR}"
echo "scenario-root: ${FIXTURE_ROOT}"
echo "google-client-plist: ${GOOGLE_DEFAULT_CLIENT_PLIST_PATH}"
echo "app-info-plist: ${GOOGLE_INFO_PLIST_PATH}"
echo "apple-signing-team-id: $(apple_signing_team_id)"
echo "apple-distribution-identity: $(apple_distribution_signing_identity)"
echo "apple-distribution-sha1: $(apple_distribution_signing_sha1)"
echo "mac-destination: ${MAC_DESTINATION}"
echo "iphone-sim-id: ${IPHONE_ID:-missing}"
echo "ipad-sim-id: ${IPAD_ID:-missing}"
echo "xcode: $(xcodebuild -version | tr '\n' ' ' | sed 's/  */ /g')"
echo "swift: $(swift --version | head -n 1)"
