#!/bin/zsh

set -euo pipefail

source "$(cd "$(dirname "$0")" && pwd)/lib/xcode-env.sh"

ensure_dirs
sync_google_client_config
require_project
load_local_env

PLATFORM=""
CONFIGURATION="Release"
ARCHIVES_DIR="${ARTIFACTS_DIR}/archives"
EXPORTS_DIR="${ARTIFACTS_DIR}/exports"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --platform)
      PLATFORM="${2:-}"
      shift 2
      ;;
    --configuration)
      CONFIGURATION="${2:-Release}"
      shift 2
      ;;
    *)
      echo "usage: ./scripts/archive-appstore --platform macos|ios [--configuration Release]" >&2
      exit 1
      ;;
  esac
done

if [[ -z "${PLATFORM}" ]]; then
  echo "usage: ./scripts/archive-appstore --platform macos|ios [--configuration Release]" >&2
  exit 1
fi

TEAM_ID="$(apple_signing_team_id)"
DIST_IDENTITY="$(apple_distribution_signing_identity)"
DIST_SHA1="$(apple_distribution_signing_sha1)"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"

mkdir -p "${ARCHIVES_DIR}"
mkdir -p "${EXPORTS_DIR}"

case "${PLATFORM}" in
  macos)
    DESTINATION="generic/platform=macOS"
    ARCHIVE_PATH="${ARCHIVES_DIR}/CalendarBusySync-macos-${TIMESTAMP}.xcarchive"
    EXPORT_PATH="${EXPORTS_DIR}/CalendarBusySync-macos-${TIMESTAMP}"
    EXPORT_METHOD="app-store-connect"
    ;;
  ios)
    DESTINATION="generic/platform=iOS"
    ARCHIVE_PATH="${ARCHIVES_DIR}/CalendarBusySync-ios-${TIMESTAMP}.xcarchive"
    EXPORT_PATH="${EXPORTS_DIR}/CalendarBusySync-ios-${TIMESTAMP}"
    EXPORT_METHOD="app-store-connect"
    ;;
  *)
    echo "expected --platform macos|ios" >&2
    exit 1
    ;;
esac

rm -rf "${ARCHIVE_PATH}"
rm -rf "${EXPORT_PATH}"
EXPORT_OPTIONS_PLIST="$(mktemp "${TMPDIR:-/tmp}/calendar-busy-sync-export-XXXXXX.plist")"
trap 'rm -f "${EXPORT_OPTIONS_PLIST}"' EXIT

cat > "${EXPORT_OPTIONS_PLIST}" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>method</key>
  <string>${EXPORT_METHOD}</string>
  <key>signingStyle</key>
  <string>automatic</string>
  <key>teamID</key>
  <string>${TEAM_ID}</string>
</dict>
</plist>
PLIST

if ! xcodebuild \
  -project "${PROJECT_PATH}" \
  -scheme "${SCHEME_NAME}" \
  -configuration "${CONFIGURATION}" \
  -destination "${DESTINATION}" \
  -archivePath "${ARCHIVE_PATH}" \
  -allowProvisioningUpdates \
  DEVELOPMENT_TEAM="${TEAM_ID}" \
  archive; then
  echo "archive failed: ensure the local Apple account can produce an archive for ${BUNDLE_IDENTIFIER} under team ${TEAM_ID}" >&2
  exit 1
fi

if ! xcodebuild \
  -exportArchive \
  -archivePath "${ARCHIVE_PATH}" \
  -exportPath "${EXPORT_PATH}" \
  -exportOptionsPlist "${EXPORT_OPTIONS_PLIST}"; then
  echo "export failed: ensure App Store distribution signing is available for ${BUNDLE_IDENTIFIER} under team ${TEAM_ID}" >&2
  exit 1
fi

if [[ "${PLATFORM}" == "macos" ]]; then
  EXPORT_SUMMARY="${EXPORT_PATH}/DistributionSummary.plist"
  if [[ -f "${EXPORT_SUMMARY}" ]]; then
    SUMMARY_TEXT="$(plutil -p "${EXPORT_SUMMARY}")"
    CERT_TYPE="$(printf '%s\n' "${SUMMARY_TEXT}" | rg -o '"type" => "Apple Distribution"' || true)"
    CERT_SHA1="$(printf '%s\n' "${SUMMARY_TEXT}" | sed -n 's/.*"SHA1" => "\(.*\)"/\1/p' | head -n 1)"
    if [[ -z "${CERT_TYPE}" ]]; then
      echo "export validation failed: expected Apple Distribution signing in ${EXPORT_SUMMARY}" >&2
      exit 1
    fi
    if [[ -n "${DIST_SHA1}" && "${CERT_SHA1}" != "${DIST_SHA1}" ]]; then
      echo "export validation failed: expected Apple Distribution cert SHA1 ${DIST_SHA1}, got ${CERT_SHA1:-unknown}" >&2
      exit 1
    fi
  fi
fi

echo "archive created at ${ARCHIVE_PATH}"
echo "export created at ${EXPORT_PATH}"
echo "expected distribution identity: ${DIST_IDENTITY}"
echo "expected distribution sha1: ${DIST_SHA1}"
